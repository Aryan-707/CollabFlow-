# CollabFlow Environment Configuration
# Copy this file to .env and update with your values

# PostgreSQL
POSTGRES_USER=collabflow
POSTGRES_PASSWORD=collabflow
POSTGRES_DB=collabflow
DATABASE_URL="postgresql://collabflow:collabflow@localhost:5432/collabflow"

# Application
NODE_ENV=development
PORT=3000

# JWT Authentication
JWT_SECRET="your-jwt-secret-change-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-change-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Redis (for BullMQ queues and Socket.io adapter)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# AI Configuration (Groq)
GROQ_API_KEY=your-groq-api-key-here

# Frontend URL
FRONTEND_URL=http://localhost:3001
CORS_ORIGIN="http://localhost:3001"

# Frontend -> Backend API URL
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api

# Queue Configuration
MAX_CONCURRENT_JOBS=5
JOB_RETRY_ATTEMPTS=3

# Logging
LOG_LEVEL=info
